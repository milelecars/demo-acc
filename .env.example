# Copy to ".env" and fill values.
# Never commit ".env" (it's gitignored).

# ---- Binance credentials (only needed for order placement) ----
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---- Runtime toggles (optional; your current code uses in-file constants) ----
TESTNET=true
INTERVAL=15m

# ---- Logging (optional) ----
LOG_LEVEL=INFO

